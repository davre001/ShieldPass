{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm install --include=dev --no-audit --no-fund && cd SDK && npx tsc && cp ../frontend/public/reusable_kyc.json dist/reusable_kyc.json && cd ../frontend && npm run build",
  "installCommand": "echo 'install handled in buildCommand'",
  "outputDirectory": "frontend/dist",
  "framework": null,
  "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cross-Origin-Opener-Policy", "value": "same-origin" },
        { "key": "Cross-Origin-Embedder-Policy", "value": "credentialless" }
      ]
    }
  ]
}
